# ---- Database (Supabase Postgres) ----
# DATABASE_URL: the POOLED connection (port 6543, via PgBouncer) — used by the app at runtime.
#   Add ?pgbouncer=true so Prisma disables prepared statements (required for PgBouncer).
# DIRECT_URL: the DIRECT connection (port 5432) — used only for running migrations.
# Both are in Supabase: Project Settings → Database → Connection string (choose "Transaction"
# pooling mode for DATABASE_URL, "Session"/direct for DIRECT_URL).
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ---- Auth ----
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-string"

# ---- App URL (used to build magic reschedule links sent via SMS) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- SMS Gateway ----
# Set to "fast2sms" or "twilio"
SMS_PROVIDER="fast2sms"

# If SMS_DRY_RUN=true, OTPs/notifications are logged to the server console
# instead of actually sent — useful for local development without SMS credits.
SMS_DRY_RUN="true"

# Fast2SMS (https://www.fast2sms.com) — free trial credits, INR pricing after
FAST2SMS_API_KEY=""

# Twilio (https://www.twilio.com) — free trial credits, alternative to Fast2SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
